<style>
!define BORDER_COLOR #1f4e8c
!define BG_NODE_COLOR #f6f8fa
!define BORDER_PALE_COLOR #7a9bc7 
!define BG_PALE_COLOR #fcfdfe 
!define BG_CONTRAST_COLOR #fff3e0
!define BORDER_CONTRAST_COLOR #e65100

diagram {
